---
layout: base.njk
---
<article>
  <header class="post-header">
    <h1>{{ title }}</h1>
    {% if subtitle %}
      <p class="post-subtitle">{{ subtitle }}</p>
    {% endif %}
    <div class="post-meta">
      <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
    </div>
  </header>
  <div class="post-content">
    {{ content | safe }}
  </div>
</article>
