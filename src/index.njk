---
layout: base.njk
title: Home
---

<div class="home-main">
  <h1>Posts</h1>

  {% if collections.post.length == 0 %}
    <p>No posts yet.</p>
  {% else %}
    <ul class="post-list">
      {% for post in collections.post | reverse %}
        <li>
          <time datetime="{{ post.date | htmlDateString }}">
            {{ post.date | readableDate }}
          </time>
          <div class="post-list-text">
            <a href="{{ post.url }}">{{ post.data.title }}</a>
            {% if post.data.subtitle %}
              <p class="post-list-subtitle">{{ post.data.subtitle }}</p>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ul>
  {% endif %}
</div>
